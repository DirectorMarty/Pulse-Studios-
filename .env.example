# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/pulse-studios

# JWT
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRY=7d

# Roblox Integration
ROBLOX_API_KEY=your_roblox_open_cloud_api_key
ROBLOX_UNIVERSE_ID=your_universe_id
ROBLOX_PLACE_ID=your_place_id

# Discord Integration
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:5000/auth/discord/callback

# OpenAI API (for AI Assistant)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Payment Processing (optional - Stripe, PayPal, etc)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
